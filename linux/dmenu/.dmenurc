#!/bin/sh
# ~/.dmenurc
#DMENU_FN="Terminus-15"
#DMENU_FN="'xos4 Source Code Pro:style=Medium:size=12'"
DMENU_NB="#16161d"
DMENU_NF="#c8c093"
